{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "functions": {
    "api/submit.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/submissions.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/confirm.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/my-stats.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/auth/callback.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/auth/me.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/auth/logout.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/ac-refresh.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/ac-create.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/ac-list.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/ac-result.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/ac-interrupt.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/ac-retry.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/ac-health.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/trending-books.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "framework": null,
  "crons": [
    {
      "path": "/api/trending-books?mode=refresh&limit=50",
      "schedule": "0 0 * * 1"
    }
  ]
}