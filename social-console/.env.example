# Discord Interactions endpoint verification
DISCORD_PUBLIC_KEY=

# Run scripts/register-discord.js locally only; do not add the bot token to Vercel.
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Long-lived Discord Gateway worker. This token is used only by the worker,
# never by Vercel Functions. Reuse neither the interaction public key nor an API token.
DISCORD_GATEWAY_SECRET=
DISCORD_GATEWAY_SEARCH_URL=https://social.novelflow.top/api/discord-gateway-search

# Restrict the assistant before inviting it to a production server.
NOVELFLOW_DISCORD_ALLOWED_GUILD_IDS=
NOVELFLOW_DISCORD_ALLOWED_ROLE_IDS=
NOVELFLOW_DISCORD_OPERATOR_TOKEN=

# Verified Discord attribution configuration from NovelFlow administration.
NOVELFLOW_DISCORD_PROMOTER=
NOVELFLOW_DISCORD_CHANNEL_NAME_ID=
NOVELFLOW_DISCORD_CHANNEL_SOURCE=Discord
NOVELFLOW_DISCORD_CHANNEL_CODE=DISCORD

# OCR adapter. Use an approved vision-capable model endpoint.
NOVELFLOW_OCR_MODEL=
NOVELFLOW_OCR_API_KEY=
NOVELFLOW_OCR_BASE_URL=

# Isolated social-console state. Configure one storage option.
KV_REST_API_URL=
KV_REST_API_TOKEN=
SOCIAL_STORE_URL=
SOCIAL_STORE_SECRET=

# Existing NovelFlow bookstore/ranking authentication.
NOVELFLOW_APPLICATION_ID=
NOVELFLOW_OIDC_TOKEN=
NOVELFLOW_OIDC_USERNAME=
NOVELFLOW_OIDC_PASSWORD=

# DeepSeek constrained candidate rerank.
NOVELFLOW_COPY_LLM_API_KEY=
NOVELFLOW_COPY_LLM_BASE_URL=https://api.deepseek.com
NOVELFLOW_COPY_LLM_MODEL=deepseek-chat
NOVELFLOW_COPY_LLM_WIRE_API=
