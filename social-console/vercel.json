{
  "cleanUrls": true,
  "functions": { "api/status.js": { "memory": 256, "maxDuration": 10 }, "api/runs.js": { "memory": 256, "maxDuration": 10 }, "api/worker.js": { "memory": 512, "maxDuration": 60 } },
  "crons": [{ "path": "/api/worker", "schedule": "*/5 * * * *" }],
  "headers": [{ "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "X-Frame-Options", "value": "DENY" }] }]
}
