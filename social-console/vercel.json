{
  "cleanUrls": true,
  "functions": { "api/status.js": { "memory": 256, "maxDuration": 10 }, "api/runs.js": { "memory": 256, "maxDuration": 10 } },
  "headers": [{ "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "X-Frame-Options", "value": "DENY" }] }]
}
