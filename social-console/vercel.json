{
  "cleanUrls": true,
  "functions": { "api/status.js": { "memory": 256, "maxDuration": 10 }, "api/leaderboard.js": { "memory": 256, "maxDuration": 30 }, "api/discord.js": { "memory": 256, "maxDuration": 10 }, "api/discord-jobs.js": { "memory": 256, "maxDuration": 10 }, "api/discord-vision.js": { "memory": 256, "maxDuration": 60 }, "api/creative-plan.js": { "memory": 512, "maxDuration": 60 }, "api/assistant.js": { "memory": 512, "maxDuration": 300 }, "api/copilot.js": { "memory": 512, "maxDuration": 60 }, "api/video-revision.js": { "memory": 512, "maxDuration": 60 }, "api/runs.js": { "memory": 512, "maxDuration": 800 }, "api/worker.js": { "memory": 512, "maxDuration": 800 } },
  "crons": [{ "path": "/api/worker", "schedule": "* * * * *" }, { "path": "/api/leaderboard", "schedule": "5 0 * * *" }],
  "rewrites": [{ "source": "/dashboard", "destination": "/" }, { "source": "/dashboard.html", "destination": "/" }],
  "headers": [{ "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "X-Frame-Options", "value": "DENY" }] }]
}
